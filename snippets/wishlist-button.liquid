{% comment %} {% if settings.enable-wishlist %} {% endcomment %}
<div
  class="wishlist_button {% if is_product == true %}product-wishlist{% endif %}"
  data-product-id="{{ product.id }}"
  data-product-title="{{ product.title }}"
  data-tooltip="Add to wishlist"
  {% if is_card_drawer == true %}
    data-product-img="{{ product.image | img_url: '' }}"
  {% else %}
    data-product-img="{{ product.featured_image | img_url: '' }}"
  {% endif %}
  {% if is_card_drawer == true %}
    data-product-price="{{ product.original_price | money | remove_first: '' }}"
  {% else %}
    data-product-price="{{ product.price | money | remove_first: '' }}"
  {% endif %}
  data-product-url="{{ product.url }}"
  {% if is_card_drawer == true %}
    data-product-variant-id="{{ product.variant.id }}"
  {% else %}
    data-product-variant-id="{{ product.selected_or_first_available_variant.id }}"
  {% endif %}
>
