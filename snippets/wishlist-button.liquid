<style>
    .wishlist_button{
      width: 30px;
      height: 30px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
    }
    {% comment %} .wishlist_button svg path{
      stroke: #000;
      fill: none;
    }
    .wishlist_button.active svg path{
      fill: #000;
  } {% endcomment %}
  .wishlist_button.active .without_fill{
    display: none;
  }
  .wishlist_button .with_fill{
    display: none;
  }
  .wishlist_button.active .with_fill{
    display: block;
  }
</style>
{% comment %}{% endif %} {% endcomment %}
