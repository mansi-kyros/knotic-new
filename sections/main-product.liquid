                  /* Different delay for each segment (premium effect) */
                  .donut-animate circle:nth-child(1) {
                    animation-delay: 0s;
                  }
                  .donut-animate circle:nth-child(2) {
                    animation-delay: 0.15s;
                  }
                  .donut-animate circle:nth-child(3) {
