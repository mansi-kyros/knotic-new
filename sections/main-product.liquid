                </style>

                <script defer>
                  function openAccordion(header, content) {
                    header.classList.add('active');
                    content.style.maxHeight = content.scrollHeight + 'px';
                    content.classList.add('open');
                  }

                  function closeAccordion(header, content) {
                    header.classList.remove('active');
                    content.style.maxHeight = null;
                    content.classList.remove('open');
                  }

                  document.addEventListener('click', (e) => {
                    const header = e.target.closest('.accordion-header');
                    if (!header || header.classList.contains('accordion-header--static')) return;

                    const content = header.nextElementSibling;

                    const isOpen = header.classList.contains('active');

                    // close all other (skip the static "Know your setting" panel —
                    // it always stays open and has no toggle icon)
                    document.querySelectorAll('.accordion-content.open').forEach((el) => {
                      const otherHeader = el.previousElementSibling;
                      if (el !== content && !otherHeader?.classList.contains('accordion-header--static')) {
                        closeAccordion(otherHeader, el);
                      }
                    });

                    // toggle
                    if (!isOpen) openAccordion(header, content);
                    else closeAccordion(header, content);
                  });

                  // FIX iOS
                  document.querySelectorAll('.accordion-content img').forEach((img) => {
                    img.addEventListener('load', () => {
                      const content = img.closest('.accordion-content');
                      if (content.classList.contains('open')) {
                        content.style.maxHeight = content.scrollHeight + 'px';
                      }
                    });
                  });

                  // "Know your setting" is already open by default via its
                  // server-rendered active/open classes + the
                  // .accordion-item--static CSS rule above — no JS needed to
                  // open it, and nothing else should auto-open on load.
                </script>

              {%- when 'rating' -%}
