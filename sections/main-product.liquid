                  @keyframes drawCircle {
                    from {
                      stroke-dashoffset: 502; /* fully hidden */
                    }
                    to {
                      stroke-dashoffset: var(--final-offset); /* reveal to final */
                    }
                  }

                  @keyframes fadeUp {
                    to {
