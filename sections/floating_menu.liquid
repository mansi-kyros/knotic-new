<!-- sections/floating_menu.liquid -->

<!-- Category Drawer -->
<div class="category-drawer" id="CategoryDrawer">
  {% comment %} <div class="drawer-overlay" data-action="close"></div> {% endcomment %}
  <div class="drawer-content">
    <div class="drawer-header-wrapper">
      <div class="drawer-header">
        {% comment %} <h4 class="heading_title">Shop by</h4> {% endcomment %}
        <button class="drawer-close" data-action="close" aria-label="Close">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="14" cy="14" r="14" fill="white"/>
            <g clip-path="url(#clip0_3760_3187)">
            <path d="M13.0934 14.0571C13.1502 14.1133 13.1502 14.2045 13.0934 14.2607L7.64221 19.6573C7.58541 19.7136 7.58541 19.8047 7.64221 19.861L8.46502 20.6756C8.52184 20.7318 8.61392 20.7318 8.67072 20.6756L14.1219 15.2789C14.1787 15.2227 14.2708 15.2227 14.3276 15.2789L19.7787 20.6756C19.8355 20.7318 19.9276 20.7318 19.9844 20.6756L20.8072 19.861C20.8641 19.8048 20.8641 19.7136 20.8072 19.6573L15.3561 14.2607C15.2993 14.2045 15.2993 14.1133 15.3561 14.0571L20.8072 8.66041C20.8641 8.60418 20.8641 8.513 20.8072 8.45677L19.9844 7.64218C19.9276 7.58595 19.8355 7.58595 19.7787 7.64218L14.3276 13.0388C14.2708 13.0951 14.1787 13.0951 14.1219 13.0388L8.67074 7.64218C8.61392 7.58595 8.52184 7.58595 8.46502 7.64218L7.64221 8.45677C7.58541 8.513 7.58541 8.60418 7.64221 8.66041L13.0934 14.0571Z" fill="black"/>
            </g>
            <defs>
            <clipPath id="clip0_3760_3187">
            <rect width="14" height="14" fill="white" transform="translate(7 7)"/>
            </clipPath>
            </defs>
          </svg>
        </button>
      </div>
      {% render 'header-search', input_id: 'Search-In-Modal', isMobile: true %}
    </div>

    <div class="drawer-inner">
      <div class="drawer-body">
        {% comment %}
          <div class="category-section">
            <h4>FEATURED</h4>
            <ul class="category-main-panel_without_child_link_list">
              {% for link in section.settings.menu.links %}
                {% if link.links.size == 0 %}
                  <li class="category-main-panel_without_child_link_list_item">
                    <a
                      class="{% if link.current %}active{% endif %}"
                      href="{{ link.url }}"
                      {% if link.current %}
                        aria-current="page"
                      {% endif %}
                    >
                      {% assign menu_title = link.title | downcase | replace: ' ', '-' %}
                      {% render 'floating_menu_images', menu_title: menu_title -%}
                      <span> {{ link.title }}</span>
                    </a>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>
        {% endcomment %}
        <div class="main-catagory">
          <ul class="category-main-panel__list">
            {% for link in section.settings.menu.links %}
              {% assign main_menu_title = link.title | downcase | replace: ' ', '-' %}
              {% if link.links.size == 0 %}
                {% assign menu_title = link.title | downcase | replace: ' ', '-' %}
                <li
                  class="category-main-panel__item {% if forloop.index == 1 %}active{% endif %}"
                  data-title="category-panel-{{ link.title | downcase | replace: ' ', '-' }}"
                >
                  <a
                    class=""
                    href="{{ link.url }}"
                    {% if link.current %}
                      aria-current="page"
                    {% endif %}
                  >
                    {% render 'floating_menu_images', menu_title: main_menu_title -%}
                    <span class="category-main-panel__title">{{ link.title }}</span>
                  </a>
                </li>
              {% else %}
                <li
                  class="category-main-panel__item {% if forloop.first %}active{% endif %}"
                  data-title="category-panel-{{ link.title | downcase | replace: ' ', '-' }}"
                >
                  {% render 'floating_menu_images', menu_title: main_menu_title -%}
                  <span class="category-main-panel__title">{{ link.title }}</span>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
        <div class="category-child-panel">
          {% for link in section.settings.menu.links %}
            {% if link.links.size > 0 %}
              <div
                class="category-child-panel__item {% if forloop.first %}active{% endif %}"
                data-title="category-panel-{{ link.title | downcase | replace: ' ', '-' }}"
              >
                {% assign main_menu_title = link.title | downcase | replace: ' ', '-' %}
                <div class="category-child-panel__sub-item swiper">
                  <ul class="category-child-panel__sub-item-ul">
                    {% for childlink in link.links %}
                      {% assign main_menu_title = childlink.title | downcase | replace: ' ', '-' %}
                      <li class="category-child-panel__sub-item-li {% if forloop.index == 1 %}sub-active{%endif %}">
                        <div class="category-child-panel__sub-item-inner">
                          <h4 class="category-child-panel__item-main-title">
                            {% render 'floating_menu_images', menu_title: main_menu_title -%}
                            <span>{{ childlink.title }}</span>
                            <svg
                              width="24"
                              height="24"
                              viewBox="0 0 24 24"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path d="M5.86426 13.75L12 7.83398L18.1367 13.75L16.667 15.167L12.416 11.0684L12 10.666L7.33399 15.167L5.86426 13.75Z" fill="black"/>
                            </svg>
                          </h4>
                          {% if childlink.links.size > 0 %}
                            <div class="child-link-content child-link-content-{{ main_menu_title }}">
                              <h5>
                                <svg
                                  width="10"
                                  height="10"
                                  viewBox="0 0 10 10"
                                  fill="none"
                                  xmlns="http://www.w3.org/2000/svg"
                                >
                                  <path d="M10 4.90721L8.42011 5.30427C7.62937 5.50286 6.91386 5.91403 6.35741 6.48961C5.80097 7.0652 5.42664 7.78135 5.27828 8.55417L5 10L4.72172 8.55417C4.57336 7.78135 4.19903 7.0652 3.64259 6.48961C3.08614 5.91403 2.37063 5.50286 1.57989 5.30427L0 4.90721L1.57989 4.51877C2.36632 4.32071 3.07853 3.91297 3.63441 3.34255C4.19029 2.77213 4.56722 2.06226 4.72172 1.29478L4.97756 0L5.23339 1.29478C5.38562 2.06366 5.76168 2.77521 6.31785 3.34669C6.87403 3.91817 7.58746 4.32611 8.37522 4.52309L10 4.90721Z" fill="#9E371E"/>
                                </svg>
                                <span>{{ childlink.title }}</span>
                              </h5>
                              {% assign childlink_title = childlink.title | downcase | replace: ' ', '-' %}
                              <ul class="category-grandchild-panel__sub-list {% if childlink_title == 'price' %}price-child{%endif %}">
                                {% for grandchildlink in childlink.links %}
                                  {% assign menu_title = grandchildlink.title | downcase | replace: ' ', '-' %}
                                  <li>
                                    <a
                                      class="{% if grandchildlink.current %}active{% endif %}"
                                      href="{{ grandchildlink.url }}"
                                      {% if grandchildlink.current %}
                                        aria-current="page"
                                      {% endif %}
                                    >
                                      {% render 'floating_menu_images', menu_title: menu_title -%}
                                      {{ grandchildlink.title -}}
                                    </a>
                                  </li>
                                {% endfor %}
                              </ul>
                            </div>
                          {% endif %}
                        </div>
                      </li>
                    {% endfor %}
                  </ul>
                  {% comment %} <div class="swiper-pagination"></div> {% endcomment %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>
{% comment %}
  <floating-menu class="floating-menu">
    <!-- Bottom Navigation -->
    <nav class="floating-nav">
      <a
        href="{{ routes.root_url }}"
        class="nav-item {% if request.page_type == 'index' %}active{% endif %}"
