<script>
  /* ============================================================
     CATEGORY DRAWER INITIALIZER (TABS ONLY)
     👉 Swiper + equal height logic COMMENTED
  ============================================================ */
  function initCategoryDrawerSystem() {
    const mainTabs = document.querySelectorAll('.category-main-panel__item');
    const childPanels = document.querySelectorAll('.category-child-panel__item');

    if (!mainTabs.length || !childPanels.length) return;

    // Reset
    mainTabs.forEach((t) => t.classList.remove('active'));
    childPanels.forEach((c) => c.classList.remove('visible'));

    const firstTab = mainTabs[0];
    const firstPanel = childPanels[0];

    if (firstTab) firstTab.classList.add('active');
    if (firstPanel) firstPanel.classList.add('visible');

    /* ---------- EQUAL HEIGHT FIX (COMMENTED) ---------- */
    /*
    function equalizeSlidesHeight(wrapper) {
      const slides = wrapper.querySelectorAll('.swiper-slide');
      if (!slides.length) return;

      let maxH = 0;

      slides.forEach((slide) => {
        slide.style.height = 'auto';
        maxH = Math.max(maxH, slide.offsetHeight);
      });

      slides.forEach((slide) => (slide.style.height = maxH + 'px'));
    }
    */

    /* ---------- SWIPER INIT (COMMENTED) ---------- */
    /*
    function initSwipersInside(panel) {
      const sliders = panel.querySelectorAll('.category-child-panel__sub-item');

      sliders.forEach((el) => {
        if (el.dataset.swiperInit === 'true') return;

        const swiper = new Swiper(el, {
          slidesPerView: 1,
          spaceBetween: 10,
          observer: true,
          observeParents: true,
          speed: 250,
          pagination: {
            el: el.querySelector('.swiper-pagination'),
            clickable: true,
          },
          on: {
            init() {
              setTimeout(() => equalizeSlidesHeight(el), 30);
            },
            resize() {
              setTimeout(() => equalizeSlidesHeight(el), 30);
            },
          },
        });

        el.swiper = swiper;
        el.dataset.swiperInit = 'true';
      });
    }
    */

    /* ---------- TAB CLICK HANDLER (NO SWIPER) ---------- */
    mainTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const title = tab.dataset.title;

        mainTabs.forEach((t) => t.classList.remove('active'));
        childPanels.forEach((p) => p.classList.remove('visible'));

        tab.classList.add('active');

        const activePanel = [...childPanels].find((p) => p.dataset.title === title);

        if (activePanel) {
          activePanel.classList.add('visible');

          // Swiper init intentionally disabled
          /*
          setTimeout(() => {
            initSwipersInside(activePanel);
          }, 30);
          */
        }
      });
    });
  }

  /* ============================================================
     CATEGORY BUTTON CLICK → OPEN DRAWER
  ============================================================ */
  document.addEventListener(
    'pointerdown',
    function (e) {
      const categoryBtn = e.target.closest("button[data-nav='category']");
      const headerBtn = e.target.closest('.header__icon--menu');

      if (!categoryBtn && !headerBtn) return;

      e.preventDefault();
      e.stopPropagation();

      const drawer = document.getElementById('CategoryDrawer');
      if (!drawer) return;

      drawer.classList.add('active');
      drawer.removeAttribute('aria-hidden');

      document.body.classList.add('overflow-hidden');
      document.body.style.overflow = 'hidden';

      setTimeout(() => {
        if (typeof initCategoryDrawerSystem === 'function') {
          initCategoryDrawerSystem();
        }
      }, 20);
    },
    true
  );

  /* ============================================================
     CLOSE BUTTON HANDLER
  ============================================================ */
  document.addEventListener('click', function (e) {
    const closeBtn = e.target.closest("[data-action='close']");
    if (!closeBtn) return;

    const drawer = document.getElementById('CategoryDrawer');
    if (!drawer) return;

    drawer.classList.remove('active');
    drawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    document.body.classList.remove('overflow-hidden-tablet', 'overflow-hidden');

    const headerDetails = document.getElementById('Details-menu-drawer-container');
    if (headerDetails) headerDetails.removeAttribute('open');

    const headerSummary = headerDetails?.querySelector('summary');
    if (headerSummary) headerSummary.setAttribute('aria-expanded', 'false');

    const mainTabs = document.querySelectorAll('.category-main-panel__item');
    const childPanels = document.querySelectorAll('.category-child-panel__item');

    mainTabs.forEach((t) => t.classList.remove('active'));
    childPanels.forEach((c) => c.classList.remove('visible'));

    // Floating nav indicator disabled
    /*
    setTimeout(updateFloatingNavActive, 20);
    */
  });

  /* ============================================================
     CATEGORY CHILD ACCORDION (H4 TOGGLE)
  ============================================================ */
  document.addEventListener('click', function (e) {
    const title = e.target.closest('.category-child-panel__item-main-title');
    if (!title) return;

    const parentLi = title.closest('.category-child-panel__sub-item-li');
    if (!parentLi) return;

    const isActive = parentLi.classList.contains('sub-active');

    /* ❌ Close all open accordions (single open UX) */
    document.querySelectorAll('.category-child-panel__sub-item-li.sub-active').forEach((item) => {
      item.classList.remove('sub-active');
    });

    /* ✅ Toggle current */
    if (!isActive) {
      parentLi.classList.add('sub-active');
    }
  });

