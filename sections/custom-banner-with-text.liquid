{%- liquid
  assign section_id = 'custom-banner-with-text-' | append: section.id
  assign desktop_image = section.settings.image_desktop
  assign mobile_image = section.settings.image_mobile | default: section.settings.image_desktop
  if section.settings.show_device == 'both'
    assign show_on_desktop = true
    assign show_on_mobile = true
  elsif section.settings.show_device == 'desktop_only'
    assign show_on_desktop = true
    assign show_on_mobile = false
  elsif section.settings.show_device == 'mobile_only'
    assign show_on_desktop = false
    assign show_on_mobile = true
  endif
-%}

{%- style -%}
  #{{ section_id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    position: relative;
    padding: var(--section-padding-top) 0 var(--section-padding-bottom);
  }

  #{{ section_id }} .image-banner__wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #ffffff;
    overflow: hidden;
    border-radius: 4px;
  }

  #{{ section_id }} .image-banner__image-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  #{{ section_id }} .image-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #{{ section_id }} .image-banner__content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    padding: 2rem;
    color: {{ section.settings.text_color }};
  }

  #{{ section_id }} .image-banner__title {
    margin: 0 0 1.5rem;
    font-size: 3.2rem;
    line-height: 1.2;
    font-weight: 700;
    color: {{ section.settings.text_color }};
  }
  #{{ section_id }} .banner-swiper__link{
    width: 100% !important;
  }

  #{{ section_id }} .image-banner__description {
    margin: 0 0 2rem;
    font-size: 1.8rem;
    line-height: 1.5;
    color: {{ section.settings.text_color }};
  }

   #{{ section_id }} .image-banner__button:hover {
    opacity: 0.95;
    transform: translateY(-1px);
  }

  #{{ section_id }} .image-banner__button {
    display: inline-block;
    padding: 1.2rem 3.2rem;
    background: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    border-radius: 50px;
    transition: transform 0.2s ease, opacity 0.2s ease;
    border: 1px solid {{ section.settings.button_border_color }};
  }

  #{{ section_id }} .image-banner__button:hover {
    opacity: 0.95;
    transform: translateY(-1px);
  }

  @media screen and (max-width: 749px) {
    #{{ section_id }} .image-banner__wrapper {
      min-height: 320px;
    }

    #{{ section_id }} .image-banner__title {
      font-size: 2.4rem;
      margin-bottom: 1rem;
    }

    #{{ section_id }} .image-banner__description {
      font-size: 1.6rem;
      margin-bottom: 1.5rem;
    }

    #{{ section_id }} .image-banner__button {
      padding: 1rem 2.4rem;
    }
  }

  {% unless show_on_desktop %}
    @media screen and (min-width: 750px) {
      #{{ section_id }} {
        display: none !important;
      }
    }
  {% endunless %}

  {% unless show_on_mobile %}
    @media screen and (max-width: 749px) {
      #{{ section_id }} {
        display: none !important;
      }
    }
  {% endunless %}
{%- endstyle -%}

<div id="{{ section_id }}" class="section-{{ section.id }}-padding">
  <div class="{% if section.settings.width_type == 'full_width' %}page-width--full{% else %}lr-padding{% endif %}">
    <div class="image-banner__wrapper">
      <div class="image-banner__image-wrapper">
        {%- if desktop_image -%}
          <picture>
            {%- if section.settings.image_mobile != blank -%}
              <source
                media="(max-width: 749px)"
                srcset="
                  {{ section.settings.image_mobile | image_url: width: 375 }} 375w,
                  {{ section.settings.image_mobile | image_url: width: 750 }} 750w,
                  {{ section.settings.image_mobile | image_url: width: 1100 }} 1100w,
                  {{ section.settings.image_mobile | image_url: width: 1500 }} 1500w
                "
                sizes="100vw"
              >
            {%- endif -%}

            <source
              media="(min-width: 750px)"
              srcset="
                {{ section.settings.image_desktop | image_url: width: 1100 }} 1100w,
                {{ section.settings.image_desktop | image_url: width: 1500 }} 1500w,
                {{ section.settings.image_desktop | image_url: width: 1780 }} 1780w,
                {{ section.settings.image_desktop | image_url: width: 2000 }} 2000w,
                {{ section.settings.image_desktop | image_url: width: 3000 }} 3000w
              "
              sizes="100vw"
            >

            <img
              src="{{ section.settings.image_desktop | image_url: width: 1500 }}"
              loading="lazy"
              class="image-banner__image"
              width="{{ section.settings.image_desktop.width }}"
              height="{{ section.settings.image_desktop.height }}"
              alt="{{ section.settings.image_desktop.alt | escape }}"
            >
          </picture>

        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'banner__image placeholder' }}
        {%- endif -%}
        <div
          class="image-banner__overlay"
          style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.4);"
        ></div>
      </div>

      <div class="image-banner__content">
        {%- if section.settings.title != blank -%}
          <h2 class="image-banner__title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="image-banner__description">{{ section.settings.description }}</div>
        {%- endif -%}

        {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
          <a href="{{ section.settings.button_link }}" class="image-banner__button">
            {{- section.settings.button_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Banner with Text",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "width_type",
      "label": "Width type",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "full_width",
          "label": "Full width"
        }
      ],
      "default": "full_width"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Image Desktop"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image Mobile (optional)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Banner heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button title",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Color Settings"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button border color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Section padding top (px)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Section padding bottom (px)",
      "default": 40
    },
    {
      "type": "select",
      "id": "show_device",
      "label": "Show on device",
      "options": [
        {
          "value": "both",
          "label": "Both"
        },
        {
          "value": "desktop_only",
          "label": "Desktop only"
        },
        {
          "value": "mobile_only",
          "label": "Mobile only"
        }
      ],
      "default": "both"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner with Text"
    }
  ]
}
{% endschema %}
