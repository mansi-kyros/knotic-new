{%- liquid
  assign section_id = 'OccasionCarousel-' | append: section.id
  if section.blocks.size > 1
    assign has_multiple_slides = section.blocks.size
  endif
  assign has_inner_slides = false
  for block in section.blocks
    if block.settings.image_2 != blank
      assign has_inner_slides = true
      break
    endif
  endfor
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --swiper-theme-color: {{ section.settings.pagination_color }};
    --swiper-navigation-size: 24px;
  }

  .occasion-carousel {
    padding: var(--section-padding-top) 0 var(--section-padding-bottom);
    position: relative;
  }

  .carousel-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 40px;
    gap: 20px;
  }

  .carousel-header__text {
    max-width: 50%;
  }

  .carousel-header__title {
    margin: 0 0 16px;
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    line-height: 1.2;
  }

  .carousel-header__description {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
  }

  .carousel-navigation {
    display: flex;
    gap: 12px;
    margin-top: 8px;
  }

