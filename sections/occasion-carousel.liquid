  .slide-card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    height: 100%;
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .slide-card__media {
    position: relative;
    padding-top: 125%;
    overflow: hidden;
    background: #f8f8f8;
  }

  .slide-card__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .slide-card__image.swiper-lazy-loaded {
    opacity: 1;
  }

  .slide-card__content {
    padding: 20px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .slide-card__title {
    margin: 0 0 20px;
    font-size: clamp(1rem, 1.2vw, 1.25rem);
    font-weight: 600;
    text-align: center;
    line-height: 1.3;
  }

  .slide-card__buttons {
    display: flex;
    gap: 12px;
    margin-top: auto;
  }

  .slide-card__button {
    flex: 1;
    padding: 10px;
    border: none;
    border-radius: 4px;
    font-weight: 500;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    font-size: 0.875rem;
    line-height: 1.3;
  }

  .swiper-pagination {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: center;
    gap: 8px;
    padding-top: 20px;
  }

  .swiper-pagination-bullet {
    width: 8px;
    height: 8px;
    background: #ddd;
    border-radius: 4px;
    opacity: 1;
    transition: all 0.3s ease;
    margin: 0 4px;
  }

  .swiper-pagination-bullet-active {
    width: 24px;
    background: var(--swiper-theme-color, #000);
  }

  /* Inner swiper for slide images */
  .slide-card__media .swiper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .slide-card__media .swiper-pagination {
    bottom: 10px;
    padding-top: 0;
  }

  .slide-card__media .swiper-pagination-bullet {
    background: rgba(255, 255, 255, 0.5);
  }

  .slide-card__media .swiper-pagination-bullet-active {
    background: #fff;
  }

  /* Responsive adjustments */
  @media screen and (max-width: 1200px) {
    .carousel-header {
      flex-direction: column;
    }

    .carousel-header__text {
      max-width: 100%;
    }

    .carousel-navigation {
      align-self: flex-end;
    }
  }

  @media screen and (max-width: 768px) {
    .swiper-slide {
      opacity: 1;
      transform: scale(1);
    }

    .swiper-slide-active {
      transform: scale(1);
    }

    .carousel-navigation {
      align-self: flex-start;
    }

    .carousel-header__text {
      max-width: 100%;
    }

    .slide-card__buttons {
      flex-direction: column;
    }

    .slide-card__button {
      width: 100%;
    }
  }

  /* Loading state */
  .swiper-lazy-preloader {
    border-color: rgba(0, 0, 0, 0.1);
    border-top-color: var(--swiper-theme-color, #000);
  }

  /* Focus styles */
  .swiper-button:focus-visible {
    outline: 2px solid var(--swiper-theme-color, #000);
    outline-offset: 2px;
  }

  .slide-card__button:focus-visible {
    outline: 2px solid var(--swiper-theme-color, #000);
    outline-offset: 2px;
  }
{%- endstyle -%}

<div
  class="occasion-carousel page-width{% if section.settings.width_type == 'full_width' %} page-width--full{% endif %}"
  id="{{ section_id }}"
  data-section-id="{{ section.id }}"
  data-has-inner-slides="{{ has_inner_slides }}"
>
  {% comment %} <div class="carousel-header">
    <div class="carousel-header__text">
      {%- if section.settings.section_title != blank -%}
        <h2 class="carousel-header__title">{{ section.settings.section_title }}</h2>
      {%- endif -%}
      {%- if section.settings.section_description != blank -%}
        <div class="carousel-header__description rte">
          {{ section.settings.section_description }}
        </div>
      {%- endif -%}
    </div>
    {%- if has_multiple_slides -%}
      <div class="carousel-navigation">
        <button
          type="button"
          class="swiper-button swiper-button-prev outer-swiper-prev"
          aria-label="Previous Slide"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button
          type="button"
          class="swiper-button swiper-button-next outer-swiper-next"
          aria-label="Next Slide"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    {%- endif -%}
  </div> {% endcomment %}

  <div class="carousel-container">
    <div
      class="swiper"
      data-swiper-type="custom-carousel"
      data-per-row-mobile="{{ section.settings.per_row_mobile | default: 1 }}"
      data-gap-mobile="{{ section.settings.gap_mobile | default: 20 }}"
      data-per-row-ipad-vertical="{{ section.settings.per_row_ipad_vertical | default: 1 }}"
      data-gap-ipad-vertical="{{ section.settings.gap_ipad_vertical | default: 20 }}"
      data-per-row-ipad-horizontal="{{ section.settings.per_row_ipad_horizontal | default: 2 }}"
      data-gap-ipad-horizontal="{{ section.settings.gap_ipad_horizontal | default: 30 }}"
      data-per-row-mac="{{ section.settings.per_row_mac | default: 3 }}"
      data-gap-mac="{{ section.settings.gap_mac | default: 40 }}"
      data-per-row-desktop="{{ section.settings.per_row_desktop | default: 3 }}"
      data-gap-desktop="{{ section.settings.gap_desktop | default: 50 }}"
      data-has-inner-slides="true"
    >
      <div class="carousel-header">
        <div class="carousel-header__text">
          {%- if section.settings.section_title != blank -%}
            <h2 class="carousel-header__title">{{ section.settings.section_title }}</h2>
          {%- endif -%}
          {%- if section.settings.section_description != blank -%}
            <div class="carousel-header__description rte">
              {{ section.settings.section_description }}
            </div>
          {%- endif -%}
        </div>
        {%- if has_multiple_slides -%}
          <div class="carousel-navigation">
            <button
              type="button"
              class="swiper-button swiper-button-prev outer-swiper-prev"
              aria-label="Previous Slide"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button
              type="button"
              class="swiper-button swiper-button-next outer-swiper-next"
              aria-label="Next Slide"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        {%- endif -%}
      </div>
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          {%- liquid
            assign has_multiple_images = block.settings.image_2
            assign image_srcset = ''

            if block.settings.image_1
              assign image_srcset = block.settings.image_1 | image_url: width: 300 | append: ' 300w,'
              assign image_srcset = image_srcset | append: block.settings.image_1 | image_url: width: 600 | append: ' 600w,'
              assign image_srcset = image_srcset | append: block.settings.image_1 | image_url: width: 900 | append: ' 900w,'
              assign image_srcset = image_srcset | append: block.settings.image_1 | image_url: width: 1200 | append: ' 1200w'
              assign image_sizes = '(max-width: 767px) calc(100vw - 40px), (max-width: 991px) calc(50vw - 60px), (max-width: 1439px) calc(33.33vw - 80px), 400px'
            endif
          -%}

          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <div class="slide-card">
              <div class="slide-card__media">
                {%- if has_multiple_images -%}
                  <div class="swiper swiper-inner" data-inner-swiper data-block-id="{{ block.id }}">
                    <div class="swiper-wrapper">
                      {%- for i in (1..3) -%}
                        {%- liquid
                          assign image_setting = 'image_' | append: i
                          assign image = block.settings[image_setting]
                        -%}
                        {%- if image != blank -%}
                          {%- assign image_srcset = image | image_url: width: 300 | append: ' 300w,' -%}
                          {%- assign image_srcset = image_srcset
                            | append: image
                            | image_url: width: 600
                            | append: ' 600w,'
                          -%}
                          {%- assign image_srcset = image_srcset
                            | append: image
                            | image_url: width: 900
                            | append: ' 900w,'
                          -%}
                          {%- assign image_srcset = image_srcset
                            | append: image
                            | image_url: width: 1200
                            | append: ' 1200w'
                          -%}
                          <div class="swiper-slide" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
                            {{
                              image
                              | image_url: width: 1200
                              | image_tag:
                                loading: 'lazy',
                                width: image.width,
                                height: image.height,
                                class: 'slide-card__image',
                                sizes: image_sizes,
                                srcset: image_srcset,
                                alt: image.alt
                              | escape
                            }}
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                    {% comment %} <div class="swiper-pagination"></div> {% endcomment %}
                    <div class="swiper-button-prev inner-swiper-prev inner-swiper-prev-{{ block.id }}"></div>
                    <div class="swiper-button-next inner-swiper-next inner-swiper-next-{{ block.id }}"></div>
                  </div>
                {%- elsif block.settings.image_1 -%}
                  {{
                    block.settings.image_1
                    | image_url: width: 1200
                    | image_tag:
                      loading: 'lazy',
                      width: block.settings.image_1.width,
                      height: block.settings.image_1.height,
                      class: 'slide-card__image swiper-lazy-loaded',
                      sizes: image_sizes,
                      srcset: image_srcset,
                      alt: block.settings.image_1.alt
                    | escape
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'slide-card__image swiper-lazy-loaded' }}
                {%- endif -%}
              </div>
              <div class="slide-card__content">
                {%- if block.settings.title != blank -%}
                  <h3 class="slide-card__title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                <div class="slide-card__buttons">
                  {%- if block.settings.button_1_label != blank -%}
                    <a
                      href="#"
                      class="slide-card__button"
                      style="
                        color: {{ block.settings.button_1_text_color }};
                        background-color: {{ block.settings.button_1_bg_color }};
                        border: 1px solid {{ block.settings.button_1_bg_color }}
                      "
                    >
                      {{ block.settings.button_1_label | escape }}
                    </a>
                  {%- endif -%}
                  {%- if block.settings.button_2_label != blank -%}
                    <a
                      href="#"
                      class="slide-card__button"
                      style="
                        color: {{ block.settings.button_2_text_color }};
                        background-color: {{ block.settings.button_2_bg_color }};
                        border: 1px solid {{ block.settings.button_2_bg_color }}
                      "
                    >
                      {{ block.settings.button_2_label | escape }}
                    </a>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
      {%- if has_multiple_slides -%}
        <div class="swiper-pagination"></div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  function initInnerSwipers(section) {
    if (!section || section.dataset.hasInnerSlides !== 'true') return;

    const innerSwipers = section.querySelectorAll('[data-inner-swiper]');

    innerSwipers.forEach((container) => {
      const blockId = container.dataset.blockId;
      if (!blockId || container.swiper) return;

      const prevBtn = container.querySelector(`.inner-swiper-prev-${blockId}`);
      const nextBtn = container.querySelector(`.inner-swiper-next-${blockId}`);

      if (!prevBtn || !nextBtn) {
        console.warn(`Missing navigation buttons for block ${blockId}`);
        return;
      }

      // 👉 PREVENT ALL EVENT LEAKING TO OUTER SWIPER
      [prevBtn, nextBtn].forEach((btn) => {
        btn.addEventListener(
          'click',
          function (e) {
            e.preventDefault();
            e.stopImmediatePropagation(); // 🔥 this is key!
          },
          { capture: true } // 🔥 this ensures it stops before Swiper listens
        );
      });

      // ✅ Init Swiper
      container.swiper = new Swiper(container, {
        loop: true,
        effect: 'fade',
        fadeEffect: {
          crossFade: true,
        },
        lazy: {
          loadPrevNext: true,
        },
        navigation: {
          nextEl: nextBtn,
          prevEl: prevBtn,
        },
      });
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    initInnerSwipers(section);
  });

  if (window.Shopify && Shopify.designMode) {
    document.addEventListener('shopify:section:load', function (event) {
      initInnerSwipers(event.target);
    });
  }
</script>

