<style>
  #diamond-{{ section.id }} {
    padding-top: 30px;
    padding-bottom: var(--pb);
    overflow: hidden;
    Background: #EAEAEA
  }

  .diamond-title {
    text-align: center;
    font-size: 28px;
    font-weight: 500;
  }

  .diamond-desc {
    text-align: center;
    font-size: 14px;
    opacity: 0.7;
    margin-bottom: 30px;
  }
  .diamond-swiper{
        padding-top: 50px
    }

  .diamond-swiper-wrapper {
    position: relative;
  }

  .diamond-swiper .swiper-wrapper {
    align-items: flex-end;
  }

  .diamond-swiper .swiper-slide {
    text-align: center;
    transform: scale(0.7) translateY(-60px);
    transition: transform 0.45s ease;
    width: calc((100% - 0 *({{ section.settings.desktop_per_row }} - 1))/{{ section.settings.desktop_per_row }}) !important
  }

  @media screen and (max-width: 1100px){
    .diamond-swiper .swiper-slide {
      width: calc((100% - 0 *({{ section.settings.ipad_horizontal }} - 1))/{{ section.settings.ipad_horizontal }}) !important;
    }
  }

  @media screen and (max-width: 786px){
    .diamond-swiper .swiper-slide {
      width: calc((100% - 0 *({{ section.settings.ipad_vertical }} - 1))/{{ section.settings.ipad_vertical }}) !important;
    }
  }

   @media screen and (max-width: 600px){
    .diamond-swiper .swiper-slide {
      width: calc((100% - 0 *({{ section.settings.mobile_per_row }} - 1))/{{ section.settings.mobile_per_row }}) !important;
    }
  }

  .diamond-swiper .swiper-slide img {
    max-width: 100%;
    margin: auto;
        width: 100%;
    height: auto;
  }

  .diamond-swiper .swiper-slide-active {
    transform: scale(1) translateY(0);
    opacity: 1;
  }

  .diamond-swiper .swiper-slide-prev{
    transform: scale(0.9) translateY(-20px) translateX(-10px);
    }
  .diamond-swiper .swiper-slide-next {
    transform: scale(0.9) translateY(-20px) translateX(10px);
  }

  .diamond-label {
    font-size: 20px;
    margin: 0;
    margin-top: 10px;
    opacity: 0;
    transition: opacity 0.45s ease;
    color: #000;

  }
  .diamond-swiper .swiper-slide-active .diamond-label{
    opacity: 1;
    }
    .details_ul{
        display: flex;
        gap: 10px;
        padding: 0;
        margin: 0;
        flex-wrap: wrap;
    }
    .details_ul li{
        list-style: none;
        width: calc((100% - 10px * (4 - 1))/4);
            line-height: normal;
            border-right: 1px solid #D7D7D7;
    }
    .details_ul li:last-child{
            border-right: none;
    }
    .details_ul li .details_wrap{
        display: flex;
        gap: 10px;
    }
    .details_ul li .details_wrap .image_wrap{
        flex: 0 0 60px;
    }
    .details_ul li .details_wrap p,
    .details_ul li .details_wrap a  {
        margin: 0;
        color: #000;
    }
    .details_ul li .details_wrap p:last-child{
        font-size: 12px !important;
    }
    .content_details .description{
        text-align: center;
        margin: 0
    }
    .content_details .description p{
      margin: 0;
      color: #000;
    }
     .content_details{
        max-width: 1440px;
        margin: 0 auto;
    }
    .diamond_details{
        padding: 30px 0;
        margin: 20px 0 50px ;
        border-top: 1px solid #D7D7D7;
        border-bottom: 1px solid #D7D7D7
    }
    .diamond-shape-section-{{ section.id }}__header{
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 10px;
        border-bottom: 1px solid #D9D9D9;
        justify-content: center;
      }
      .diamond-shape-section-{{ section.id }}__header h2{
        margin: 0;
        text-align: center;
      }
     @media screen and (min-width: 750px){
    .details_ul li:nth-child(2) .details_wrap,
    .details_ul li:nth-child(3) .details_wrap{
      justify-content: center;
    }
    .details_ul li:first-child .details_wrap{
      justify-content: left;
    }
    .details_ul li:last-child .details_wrap{
      justify-content: center;
    }
    }
    @media screen and (max-width: 749px){
        .details_ul li{
        width: calc((100% - 10px * (2 - 1))/2);
        border-right: none;
    }
    .details_ul li .details_wrap .image_wrap{
      flex: 0 0 40px;
    }
    .details_ul li .details_wrap .image_wrap img{
      width: 40px;
      height: 40px;
    }
    .details_ul{
      position: relative
    }
    .details_ul:after{
      width: 1px;
      height: 100%;
      background: #D7D7D7;
      content: "";
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%)
    }
    .details_ul:before{
      width: 100%;
      height: 1px;
      background: #D7D7D7;
      content: "";
      position: absolute;
      top: 50%;
      left: 0;
      transform: translateY(-50%)
    }
    .details_ul li:first-child,
    .details_ul li:nth-child(2){
      padding-bottom: 20px;
    }
    .details_ul li:nth-child(3),
    .details_ul li:nth-child(4){
      padding-top: 20px;
    }
    .diamond_details{
      padding: 20px 0
    }
     .details_ul li:first-child,
    .details_ul li:nth-child(3){
      padding-right: 10px;
    }
    .details_ul li:nth-child(2),
    .details_ul li:nth-child(4){
      padding-left: 10px;
    }
    #diamond-{{ section.id }} {
    padding-top: 30px;
    }
    }
</style>

<section
  class="diamond-shape-section"
  data-device="{{ section.settings.device_show }}"
  id="diamond-{{ section.id }}"
>
  <div class="lr-padding">
    {% if section.settings.title != blank %}
      <div class="diamond-shape-section-{{ section.id }}__header heading_wraper">
        {% if section.settings.title != blank %}
          <h2>{{ section.settings.title }}</h2>
        {% endif %}
      </div>
    {% endif %}

    <div class="diamond-swiper-wrapper">
      <div class="swiper diamond-swiper">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide">
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.label }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
              <p class="diamond-label">{{ block.settings.label }}</p>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
    <div class="content_details">
      <div class="description">
        {{ section.settings.description }}
      </div>
      <div class="diamond_details">
        <ul class="details_ul">
          <li class="details_li">
            <div class="details_wrap">
              <div class="image_wrap">
                <img
                  src="https://cdn.shopify.com/s/files/1/0774/4104/0612/files/icon_carat.svg?v=1766042175"
                  width="60px"
                  height="60px"
                >
              </div>
              <div class="contant_wrap">
                <p> <a href="https://knotic-jewel.myshopify.com/pages/4cs-of-diamond/#carat"> Carat</a></p>
                <p>Multiple Carat Options </p>
              </div>
            </div>
          </li>
          <li class="details_li">
            <div class="details_wrap">
              <div class="image_wrap">
                <img
                  src="https://cdn.shopify.com/s/files/1/0774/4104/0612/files/icon_clarity.svg?v=1766042176"
                  width="50px"
                  height="50px"
                >
              </div>
              <div class="contant_wrap">
                <p><a href="https://knotic-jewel.myshopify.com/pages/4cs-of-diamond/#clarity"> Clarity </a></p>
                <p>VVS Clarity </p>
              </div>
            </div>
          </li>
          <li class="details_li">
            <div class="details_wrap">
              <div class="image_wrap">
                <img
                  src="https://cdn.shopify.com/s/files/1/0774/4104/0612/files/icon_carat.svg?v=1766042175"
                  width="50px"
                  height="50px"
                >
              </div>
              <div class="contant_wrap">
                <p><a href="https://knotic-jewel.myshopify.com/pages/4cs-of-diamond/#colour">Colour  </a></p>
                <p>E/F Color </p>
              </div>
            </div>
          </li>
          <li class="details_li">
            <div class="details_wrap">
              <div class="image_wrap">
                <img
                  src="https://cdn.shopify.com/s/files/1/0774/4104/0612/files/icon_cut.svg?v=1766042176"
                  width="50px"
                  height="50px"
                >
              </div>
              <div class="contant_wrap">
                <p><a href="https://knotic-jewel.myshopify.com/pages/4cs-of-diamond/#cut"> Cut </a></p>
                <p>Excellent Cut</p>
              </div>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    function initDiamondSwiper() {
      const el = document.querySelector(
        "#diamond-{{ section.id }} .diamond-swiper"
      );

      if (!el || typeof Swiper === "undefined") return false;

      new Swiper(el, {
        loop: true,
        centeredSlides: true,
        grabCursor: true,
        speed: 600,
        mousewheel: {
    forceToAxis: true,
    sensitivity: 1,
  },
  touchReleaseOnEdges: true,
        watchSlidesProgress: true,

        lazy: {
          loadPrevNext: true
        },

        breakpoints: {
          0: {
            slidesPerView: {{ section.settings.mobile_per_row }}
          },
          768: {
            slidesPerView: {{ section.settings.ipad_vertical }}
          },
          990: {
            slidesPerView: {{ section.settings.ipad_horizontal }}
          },
          1200: {
            slidesPerView: {{ section.settings.desktop_per_row }}
          }
        }
      });

      return true;
    }

    // Try immediately
    if (initDiamondSwiper()) return;

    // Retry until Swiper loads
    let retryCount = 0;
    const retry = setInterval(() => {
      retryCount++;
      if (initDiamondSwiper() || retryCount > 20) {
        clearInterval(retry);
      }
    }, 150);
  })();
</script>

{% schema %}
{
  "name": "Diamond Shape Swiper",
  "settings": [
    { "type": "html", "id": "title", "label": "Section title" },
    { "type": "richtext", "id": "description", "label": "Section description" },

    {
      "type": "range",
      "id": "desktop_per_row",
      "label": "Desktop per row",
      "min": 1,
      "max": 10,
      "step": 0.1,
      "default": 5
    },
    {
      "type": "range",
      "id": "ipad_horizontal",
      "label": "iPad Horizontal",
      "min": 1,
      "max": 10,
      "step": 0.1,
      "default": 4
    },
    {
      "type": "range",
      "id": "ipad_vertical",
      "label": "iPad Vertical",
      "min": 1,
      "max": 10,
      "step": 0.1,
      "default": 3
    },
    { 
      "type": "range", 
      "id": "mobile_per_row", 
      "label": "Mobile", "min": 1,
       "max": 5, "step": 0.1, 
       "default": 1.8 
    },

    {
      "type": "select",
      "id": "device_show",
      "label": "Device show",
      "options": [
        { "value": "both", "label": "Both" },
        { "value": "desktop", "label": "Only Desktop" },
        { "value": "mobile", "label": "Only Mobile" }
      ],
      "default": "both"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Diamond",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Diamond image" },
        { "type": "text", "id": "label", "label": "Diamond name" }
      ]
    }
  ],
  "presets": [{ "name": "Diamond Shape Swiper" }]
}
{% endschema %}
