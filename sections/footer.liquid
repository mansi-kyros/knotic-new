                              href="{{ block.settings.flipkart_url }}"
                              aria-label=""
                              class="footer_Channel_Partner__link flipkart_icon"
                            >
                              <img
                                src="{{ block.settings.flipkart_icon | image_url: width: 30, height: 30 }}"
                                alt=""
                                width="30px"
                                height="30px"
                              >
                            </a>
                          {%- endif -%}
                          {%- if block.settings.amazon_icon -%}
                            <a
                              href="{{ block.settings.amazon_url }}"
                              aria-label=""
                              class="footer_Channel_Partner__link amazon_icon"
                            >
                              <img
                                src="{{ block.settings.amazon_icon | image_url: width: 30, height: 30 }}"
                                alt=""
