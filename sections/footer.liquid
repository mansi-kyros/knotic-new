                                  </svg>
                                </span>
                                <span class="text">{{ block.settings.email }}</span>
                              </div>
                            {% endif %}
                            {% if block.settings.phone != blank %}
                              <div class="icon_with_text_wrap rte">
                                <span class="icon">
