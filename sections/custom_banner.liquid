        {
          "value": "only_desktop",
          "label": "Only Desktop"
        },
        {
          "value": "only_mobile",
          "label": "Only Mobile"
        }
      ],
      "default": "both"
    },
    {
      "type": "header",
      "content": "Swiper Settings"
    },
    {
      "type": "select",
