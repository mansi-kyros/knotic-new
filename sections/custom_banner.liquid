          "label": "Bullets"
        },
        {
          "value": "progressbar",
          "label": "Progress Bar"
        }
      ],
      "default": "bullets"
    },
    {
      "type": "color",
      "id": "arrow_background_color",
      "label": "Arrow Background Color",
      "default": "rgba(0,0,0,0.5)"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "arrow_background_color_hover",
      "label": "Arrow Background Color Hover",
      "default": "#fff"
    },
    {
      "type": "color",
      "id": "arrow_color_hover",
      "label": "Arrow Color_hover",
      "default": "#000"
    },
    {
      "type": "color",
      "id": "pagination_color",
      "label": "Pagination Color",
      "default": "#fff"
    },
    {
      "type": "color",
      "id": "pagination_active_color",
      "label": "Active Pagination Color",
      "default": "#000"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Desktop Media"
        },
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop Image",
          "info": "Recommended size: 1920x1080px"
        },
        {
          "type": "video",
          "id": "desktop_video",
          "label": "Desktop Video (Optional)"
        },
        {
          "type": "header",
          "content": "iPad Media"
        },
        {
          "type": "image_picker",
          "id": "ipad_image",
          "label": "iPad Image (Optional)",
          "info": "Recommended size: 1024x768px"
        },
        {
          "type": "video",
          "id": "ipad_video",
          "label": "iPad Video (Optional)"
